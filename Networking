#include <stdio.h>
#include <stdlib.h>

struct frame {
    int info;
    int seq;
};

struct frame p;
int ack;
char turn = 's';
int errorframe = 1;
int errorack = 1;

void sender();
void receiver();

int main() {
    p.info = 0;
    p.seq = 0;

    while (p.seq < 5) {
        sender();
        receiver();
    }

    return 0;
}

void sender() {
    if (turn == 's') {
        printf("SENDER: Sent packet with seq %d\n", p.seq);

        errorframe = rand() % 4;

        if (errorframe == 0)
            printf("Error while sending packet\n");

        turn = 'r';
    }
}

void receiver() {
    if (turn == 'r') {
        if (errorframe != 0) {
            printf("RECEIVER: Received packet %d\n", p.seq);

            ack = p.seq;
            printf("RECEIVER: Sent ACK %d\n", ack);

            p.seq++;
        } else {
            printf("RECEIVER: Packet lost\n");
        }

        turn = 's';
    }
}





